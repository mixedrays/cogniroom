{
  "name": "cogniroom",
  "private": true,
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "sync-instructions": "./scripts/sync-instructions.sh",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
