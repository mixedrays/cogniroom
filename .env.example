# OpenAI API Key (required for LLM features)
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY="your_openai_api_key_here"

# Optional: Anthropic API Key (alternative LLM provider)
ANTHROPIC_API_KEY="your_anthropic_api_key_here"

# Optional: OpenRouter API Key (access many models via OpenRouter)
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY="your_openrouter_api_key_here"

# Persisted data root — courses, prompts, settings, chat history (default: ./data)
DATA_PATH=./data

# Authoritative store for all user data (default: filesystem).
#   filesystem — server persists under DATA_PATH (local dev, writable disk).
#   browser    — the browser's IndexedDB is the source of truth; the server
#                filesystem is disabled. Use on read-only serverless hosts
#                (e.g. Vercel), where DATA_PATH is not writable.
STORAGE_MODE=filesystem

APP_NAME=CogniRoom